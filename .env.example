# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── WORKER SERVICE ID ───────────────────────────────────────────────
# The registered service ID for this research provider. Register the
# service in the CROO Dashboard, then paste its ID here. (Maestro hires
# this as both WORKER_SERVICE_ID and, optionally, WORKER_FALLBACK_SERVICE_ID.)
WORKER_SERVICE_ID=

# ── ANTHROPIC API KEY ───────────────────────────────────────────────
# Used to write the research draft. If unset, the Worker produces a
# deterministic offline draft (so mock mode and CI work without a key).
ANTHROPIC_API_KEY=

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
